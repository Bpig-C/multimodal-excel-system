# ============================================================
# 后端环境变量模板 - 复制为 .env 并填写实际值
# 所有带 * 的项目为必填
# ============================================================

# ------------------------------------------------------------
# 数据库（必填*）
# 格式1：绝对路径  sqlite:////home/user/app/data/database/annotation.db
# 格式2：相对路径  data/database/annotation.db（相对于 backend/ 目录）
# ------------------------------------------------------------
DATABASE_URL=sqlite:////home/your_user/app/data/database/annotation.db

# ------------------------------------------------------------
# LLM API（必填*，不配置则批量标注功能不可用）
# ------------------------------------------------------------
DASHSCOPE_API_KEY=sk-your-dashscope-api-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ------------------------------------------------------------
# CORS（必填*，填写前端部署后的 Vercel 域名）
# 多个域名用逗号分隔，不要有空格
# 示例：https://your-app.vercel.app,https://your-custom-domain.com
# ------------------------------------------------------------
CORS_ORIGINS=https://your-app.vercel.app

# ------------------------------------------------------------
# 服务器（可选，有默认值）
# ------------------------------------------------------------
HOST=0.0.0.0
PORT=18080

# ------------------------------------------------------------
# 存储方式（可选，默认 local）
# local：使用服务器本地目录存储文件
# minio：使用 MinIO 对象存储（需填写下方 MinIO 配置）
# ------------------------------------------------------------
STORAGE_TYPE=local

# MinIO 配置（仅 STORAGE_TYPE=minio 时需要填写）
# MINIO_ENDPOINT=localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=annotation-images
# MINIO_SECURE=false
# MINIO_PUBLIC_URL=

# ------------------------------------------------------------
# LLM 超时与重试（可选）
# ------------------------------------------------------------
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=1
