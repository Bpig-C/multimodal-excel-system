# ============================================================
# 前端环境变量模板 - 复制为 .env.production 并填写实际值
# ============================================================

# API 前缀（通常不需要修改）
VITE_API_BASE_URL=/api/v1

# 后端服务地址（Vercel 部署时必填，填写后端的完整 URL）
# 例如：https://your-backend.railway.app
# 例如：https://your-backend.onrender.com
# 例如：https://your-server-ip（自有服务器）
VITE_BACKEND_ORIGIN=

# 应用标题
VITE_APP_TITLE=面向离散型电子信息制造业的多模态语料库构建平台
